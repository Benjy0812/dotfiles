# Shell Abbreviations (auto-expand while typing)

# Git
abbr -a gs git status
abbr -a ga git add
abbr -a gc git commit -m
abbr -a gch git checkout
abbr -a gaa git add .
abbr -a gm git merge

# Navigation
abbr -a home cd ~
abbr -a conf cd ~/.config

# Directory operations
abbr -a mkd mkdir -p
abbr -a rmd rmdir
abbr -a rmrf rm -rf

# Common commands
abbr -a buni bun install
abbr -a bunf bun run format
abbr -a bund bun run dev
abbr -a bunb bun run build
abbr -a py python3
