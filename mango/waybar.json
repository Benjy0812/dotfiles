{
  "layer": "top",
  "position": "top",
  "height": 42,
  "spacing": 10,

  "modules-left": ["ext/workspaces", "dwl/window"],
  "modules-center": ["clock"],
  "modules-right": ["cpu", "memory", "pulseaudio", "network"],

  "ext/workspaces": {
    "format": "{id}",
    "format-urgent": "{id}",
    "ignore-hidden": true,
    "sort-by-id": true,
    "all-outputs": false,
    "on-click": "activate"
  },

  "dwl/window": {
    "format": "[{layout}] {title}"
  },

  "clock": {
    "format": "{:%H:%M:%S}",
    "format-alt": "{:%A %B %d}",
    "interval": 1,
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>"
  },

  "cpu": {
    "format": "CPU {usage}%",
    "interval": 1,
    "max-length": 10
  },

  "memory": {
    "format": "MEM {percentage}%",
    "interval": 1
  },

  "pulseaudio": {
    "format": "♪ {volume}%",
    "format-muted": "♪ muted",
    "on-click": "pavucontrol"
  },

  "network": {
    "format-wifi": "󰤨 {essid}",
    "format-ethernet": "󰌘 Eth",
    "format-disconnected": "󰌘 off",
    "interval": 30
  }
}
